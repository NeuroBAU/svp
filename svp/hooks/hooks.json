{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "handler": {
          "type": "command",
          "command": ".claude/scripts/write_authorization.sh"
        }
      },
      {
        "matcher": "Bash",
        "handler": {
          "type": "command",
          "command": ".claude/scripts/non_svp_protection.sh"
        }
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "handler": {
          "type": "command",
          "command": ".claude/scripts/stub_sentinel_check.sh"
        }
      },
      {
        "matcher": "Agent",
        "handler": {
          "type": "command",
          "command": ".claude/scripts/monitoring_reminder.sh"
        }
      }
    ]
  }
}