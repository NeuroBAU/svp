{
  "toolchain_id": "r_conda_testthat",
  "environment": {
    "tool": "conda",
    "run_prefix": "conda run -n {env_name}",
    "create_command": "conda create -n {env_name} -c conda-forge r-base={r_version} {framework_packages} {quality_packages} -y",
    "install_command": "conda install -n {env_name} -c conda-forge {packages} -y",
    "install_dev": "conda run -n {env_name} Rscript -e 'devtools::install(\".\")'",
    "cleanup_command": "conda env remove -n {env_name} -y",
    "verify_commands": [
      "{run_prefix} R --version",
      "{run_prefix} Rscript -e 'library(testthat); cat(\"OK\")'",
      "{run_prefix} Rscript -e 'library(covr); cat(\"OK\")'",
      "{run_prefix} quarto --version"
    ]
  },
  "quality": {
    "formatter": {
      "tool": "styler",
      "format": "{run_prefix} Rscript -e 'styler::style_dir(\"R/\")'",
      "check": "{run_prefix} Rscript -e 'styler::style_dir(\"R/\", dry=\"check\")'"
    },
    "linter": {
      "tool": "lintr",
      "light": "{run_prefix} Rscript -e 'lintr::lint_dir(\"R/\")'",
      "heavy": "{run_prefix} Rscript -e 'lintr::lint_dir(\"R/\")'",
      "check": "{run_prefix} Rscript -e 'lintr::lint_dir(\"R/\")'"
    },
    "type_checker": {
      "tool": "none"
    },
    "packages": [
      "r-lintr",
      "r-styler",
      "r-covr",
      "r-devtools"
    ],
    "gate_a": [
      "formatter.format"
    ],
    "gate_b": [
      "formatter.format",
      "linter.light"
    ],
    "gate_c": [
      "formatter.check",
      "linter.check"
    ]
  },
  "testing": {
    "tool": "testthat",
    "run_command": "{run_prefix} Rscript -e 'devtools::test(reporter = testthat::SilentReporter$new(), stop_on_failure = FALSE)'",
    "run_coverage": "{run_prefix} Rscript -e 'suppressMessages(devtools::load_all(\".\", export_all = TRUE, quiet = TRUE)); pkg <- as.character(read.dcf(\"DESCRIPTION\")[1, \"Package\"]); cov <- covr::environment_coverage(asNamespace(pkg), test_files = list.files(\"tests/testthat\", pattern = \"^test-.*\\\\.R$\", full.names = TRUE)); cat(round(covr::percent_coverage(cov), 2), \"\\n\")'",
    "framework_packages": [
      "r-covr",
      "r-devtools",
      "r-testthat"
    ],
    "file_pattern": "test-*.R",
    "collection_error_indicators": [
      "Error in library",
      "there is no package called",
      "could not find function"
    ],
    "unit_flags": "",
    "project_flags": ""
  },
  "vcs": {
    "tool": "git",
    "commands": {
      "init": "git init",
      "add": "git add {files}",
      "commit": "git commit -m \"{message}\"",
      "status": "git status"
    }
  },
  "language": {
    "name": "r",
    "extension": ".R",
    "version_constraint": ">=4.3",
    "stub_body": "stop('Not implemented')"
  },
  "file_structure": {
    "source_dir_pattern": "R",
    "test_dir_pattern": "tests/testthat",
    "source_extension": ".R",
    "test_extension": ".R"
  },
  "language_architecture_primers": {}
}
